{
  "Quality": [
    {
      "Column": "CashflowFree",
      "Formula": "CashflowStatement.operatingCashflow + CashflowStatement.investmentCashflow"
    },
    {
      "Column": "CashflowEquity",
      "Formula": "CashflowStatement.dividends + CashflowStatement.buybacks"
    },
    {
      "Column": "CashflowDebt",
      "Formula": "CashflowStatement.financingCashflow - Quality.CashflowEquity"
    },
    {
      "Column": "TotalLiabilities",
      "Formula": "BalanceSheet.totalAssets - BalanceSheet.shareholdersEquity"
    },
    {
      "Column": "NonCurrentLiabilities",
      "Formula": "Quality.TotalLiabilities - BalanceSheet.currentLiabilities"
    },
    {
      "Column": "NCAV",
      "Formula": "BalanceSheet.currentAssets - Quality.TotalLiabilities"
    },
    {
      "Column": "DebtToEquity",
      "Formula": "Quality.TotalLiabilities / BalanceSheet.shareholdersEquity"
    },
    {
      "Column": "CurrentRatio",
      "Formula": "BalanceSheet.currentAssets / BalanceSheet.currentLiabilities"
    },
    {
      "Column": "LiquidAssetsRatio",
      "Formula": "BalanceSheet.currentAssets / BalanceSheet.totalAssets"
    },
    {
      "Column": "ReturnOnEquity",
      "Formula": "IncomeStatement.netIncome / BalanceSheet.shareholdersEquity"
    },
    {
      "Column": "ReturnOnAssets",
      "Formula": "IncomeStatement.netIncome / BalanceSheet.totalAssets"
    },
    {
      "Column": "GrossMargin",
      "Formula": "IncomeStatement.grossProfit / IncomeStatement.netSales"
    },
    {
      "Column": "OperatingMargin",
      "Formula": "IncomeStatement.operatingIncome / IncomeStatement.netSales"
    },
    {
      "Column": "NetProfitMargin",
      "Formula": "IncomeStatement.netIncome / IncomeStatement.netSales"
    },
    {
      "Column": "AssetTurnover",
      "Formula": "IncomeStatement.netSales / BalanceSheet.totalAssets"
    },
    {
      "Column": "BuybackPayout",
      "Formula": "((-1) * CashflowStatement.buybacks) / IncomeStatement.netIncome"
    },
    {
      "Column": "ShareholderPayout",
      "Formula": "((-1) * Quality.CashflowEquity) / IncomeStatement.netIncome"
    },
    {
      "Column": "DividendPayout",
      "Formula": "((-1) * CashflowStatement.dividends) / IncomeStatement.netIncome"
    },
    {
      "Column": "FreeCashflowMargin",
      "Formula": "Quality.CashflowFree / IncomeStatement.netSales"
    },
    {
      "Column": "CashflowToEquityMargin",
      "Formula": "Quality.CashflowEquity / IncomeStatement.netSales"
    },
    {
      "Column": "CashflowToDebtMargin",
      "Formula": "Quality.CashflowDebt / IncomeStatement.netSales"
    },
    {
      "Column": "DepreciationToPPE",
      "Formula": "CashflowStatement.depreciation / BalanceSheet.ppe"
    },
    {
      "Column": "InventoryCashflow",
      "Formula": "CashflowStatement.cashflowInventories / IncomeStatement.netSales"
    },
    {
      "Column": "CapexToAssets",
      "Formula": "CashflowStatement.capex / BalanceSheet.totalAssets"
    },
    {
      "Column": "CapexToSales",
      "Formula": "CashflowStatement.capex / IncomeStatement.netSales"
    },
    {
      "Column": "CapexToDepreciation",
      "Formula": "CashflowStatement.capex / CashflowStatement.depreciation"
    },
    {
      "Column": "CapexToPPE",
      "Formula": "CashflowStatement.capex / BalanceSheet.ppe"
    }
  ],
  "PerShare": [
    {
      "Column": "BookValue",
      "Formula": "BalanceSheet.shareholdersEquity / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "EPS",
      "Formula": "IncomeStatement.netIncome / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "Sales",
      "Formula": "IncomeStatement.netSales / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "NCAV",
      "Formula": "Quality.NCAV / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "CashflowFree",
      "Formula": "Quality.CashflowFree / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "CashflowEquity",
      "Formula": "Quality.CashflowEquity / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "CashflowDebt",
      "Formula": "Quality.CashflowDebt / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "Dividends",
      "Formula": "((-1) * CashflowStatement.dividends) / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "Buybacks",
      "Formula": "((-1) * CashflowStatement.buybacks) / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "TotalPayout",
      "Formula": "PerShare.Buybacks + PerShare.Dividends"
    },
    {
      "Column": "CashAndEquivalents",
      "Formula": "BalanceSheet.cash / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "PPE",
      "Formula": "BalanceSheet.ppe / FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "IntangibleAssets",
      "Formula": "BalanceSheet.intangibleAssets / FinancialStatements.SharesOutstanding"
    }
  ],
  "Valuation": [
    {
      "Column": "PERatio",
      "Formula": "FinancialStatements.SharePrice / PerShare.EPS"
    },
    {
      "Column": "EarningsYield",
      "Formula": "PerShare.EPS / FinancialStatements.SharePrice"
    },
    {
      "Column": "PriceToSales",
      "Formula": "FinancialStatements.SharePrice / PerShare.Sales"
    },
    {
      "Column": "PriceToBook",
      "Formula": "FinancialStatements.SharePrice / PerShare.BookValue"
    },
    {
      "Column": "PriceToNCAV",
      "Formula": "FinancialStatements.SharePrice / PerShare.NCAV"
    },
    {
      "Column": "FreeCashflowYield",
      "Formula": "PerShare.CashflowFree / FinancialStatements.SharePrice"
    },
    {
      "Column": "DividendsYield",
      "Formula": "PerShare.Dividends / FinancialStatements.SharePrice"
    },
    {
      "Column": "BuybacksYield",
      "Formula": "PerShare.Buybacks / FinancialStatements.SharePrice"
    },
    {
      "Column": "TotalPayoutYield",
      "Formula": "PerShare.TotalPayout / FinancialStatements.SharePrice"
    },
    {
      "Column": "MarketCap",
      "Formula": "FinancialStatements.SharePrice * FinancialStatements.SharesOutstanding"
    },
    {
      "Column": "EnterpriseValue",
      "Formula": "Valuation.MarketCap + Quality.TotalLiabilities"
    },
    {
      "Column": "EnterpriseValueToSales",
      "Formula": "Valuation.EnterpriseValue / IncomeStatement.netSales"
    }
  ]
}
